<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>sockseek</AssemblyName>
    <RootNamespace>Sockseek.Cli</RootNamespace>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <DefineConstants>$(DefineConstants);TRACE</DefineConstants>
    <DebugType>portable</DebugType>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <DebugType>portable</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Client" Version="10.0.9" />
    <PackageReference Include="Microsoft.AspNetCore.SignalR.Protocols.Json" Version="10.0.9" />
    <PackageReference Include="Spectre.Console" Version="0.54.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Sockseek.Api/Sockseek.Api.csproj" />
    <ProjectReference Include="../Sockseek.Core/Sockseek.Core.csproj" />
    <ProjectReference Include="../Sockseek.Server/Sockseek.Server.csproj" />
  </ItemGroup>

  <!-- Trimming configuration.
       TrimMode=partial restores the .NET 6 trimming behavior: only assemblies that have explicitly opted
       into trimming are trimmed. This prevents the .NET 8 default member-level trimming from stripping
       overloads that are only reachable via dynamic dispatch (e.g. Soulseek.NET's Waiter.Cancel uses
       'dynamic' to call TaskCompletionSource<T>.TrySetCanceled(CancellationToken), and the .NET 8
       aggressive trimmer removes that overload since it's not statically reachable).

       TagLibSharp: uses Activator.CreateInstance via reflection to create format-specific file types (Ogg, Mpeg, etc.) —
         the trimmer cannot trace these as reachable so strips their constructors.
       Newtonsoft.Json: transitively required by SpotifyAPI.Web and Google.Apis.Core; notoriously reflection-heavy
         serializer that is explicitly not trim-compatible and will produce IL2104 warnings / runtime failures when trimmed. -->
  <PropertyGroup Condition="'$(PublishTrimmed)' == 'true'">
    <TrimMode>partial</TrimMode>
  </PropertyGroup>
  <ItemGroup Condition="'$(PublishTrimmed)' == 'true'">
    <TrimmerRootAssembly Include="Sockseek.Api" />
    <TrimmerRootAssembly Include="Sockseek.Core" />
    <TrimmerRootAssembly Include="Sockseek.Server" />
    <TrimmerRootAssembly Include="Soulseek" />
    <TrimmerRootAssembly Include="SpotifyAPI.Web" />
    <TrimmerRootAssembly Include="SpotifyAPI.Web.Auth" />
    <TrimmerRootAssembly Include="Google.Apis" />
    <TrimmerRootAssembly Include="Google.Apis.Core" />
    <TrimmerRootAssembly Include="Google.Apis.YouTube.v3" />
    <TrimmerRootAssembly Include="EmbedIO" />
    <TrimmerRootAssembly Include="HtmlAgilityPack" />
    <TrimmerRootAssembly Include="AngleSharp" />
    <TrimmerRootAssembly Include="TagLibSharp" />
    <TrimmerRootAssembly Include="Newtonsoft.Json" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../README.md" />
  </ItemGroup>

  <PropertyGroup>
    <HelpGeneratorTargetFramework>net10.0</HelpGeneratorTargetFramework>
    <HelpGeneratorProject>../Sockseek.HelpGenerator/Sockseek.HelpGenerator.csproj</HelpGeneratorProject>
    <HelpGeneratorDll>../Sockseek.HelpGenerator/bin/$(Configuration)/$(HelpGeneratorTargetFramework)/Sockseek.HelpGenerator.dll</HelpGeneratorDll>
    <HelpValidationStamp>$(MSBuildProjectDirectory)/obj/$(Configuration)/$(TargetFramework)/HelpContent.validation.stamp</HelpValidationStamp>
  </PropertyGroup>

  <Target Name="BuildHelpGenerator"
          Condition="'$(DesignTimeBuild)' != 'true' and '$(SkipCompilerExecution)' != 'true'"
          Inputs="../Sockseek.HelpGenerator/Program.cs;../Sockseek.HelpGenerator/Sockseek.HelpGenerator.csproj"
          Outputs="$(HelpGeneratorDll)">
    <MSBuild Projects="$(HelpGeneratorProject)"
             Targets="Build"
             Properties="Configuration=$(Configuration);TargetFramework=$(HelpGeneratorTargetFramework)"
             RemoveProperties="RuntimeIdentifier;SelfContained;PublishSelfContained;PublishSingleFile;PublishTrimmed;PublishReadyToRun;PublishAot" />
  </Target>

  <Target Name="GenerateHelpFile"
          Condition="'$(DesignTimeBuild)' != 'true' and '$(SkipCompilerExecution)' != 'true'"
          BeforeTargets="CoreCompile"
          DependsOnTargets="BuildHelpGenerator"
          Inputs="../README.md;../Sockseek.HelpGenerator/Program.cs"
          Outputs="Help.Content.cs">
    <Message Text="Help.Content.cs is out of date, regenerating from README.md..." Importance="high" />
    <Exec Command="dotnet &quot;$(HelpGeneratorDll)&quot;" />
    <Touch Files="$(HelpValidationStamp)" AlwaysCreate="true" />
  </Target>

  <Target Name="ValidateGeneratedHelpFile"
          Condition="'$(DesignTimeBuild)' != 'true' and '$(SkipCompilerExecution)' != 'true'"
          BeforeTargets="CoreCompile"
          DependsOnTargets="BuildHelpGenerator;GenerateHelpFile"
          Inputs="../README.md;../Sockseek.HelpGenerator/Program.cs;Help.Content.cs"
          Outputs="$(HelpValidationStamp)">
    <Exec Command="dotnet &quot;$(HelpGeneratorDll)&quot; --check" />
    <Touch Files="$(HelpValidationStamp)" AlwaysCreate="true" />
  </Target>

</Project>
